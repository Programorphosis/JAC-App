# ══════════════════════════════════════════════════════════════════════════
# .env.production.example — Variables de entorno para producción
#
# INSTRUCCIONES:
#   1. Copiar:    cp .env.production.example .env.production
#   2. Completar los valores marcados con <CAMBIAR> o <GENERAR>
#   3. NUNCA subir .env.production al repositorio (está en .gitignore)
#
# IMPORTANTE (evita "key cannot contain a space"):
#   Valores con espacios OBLIGATORIAMENTE entre comillas: EMAIL_FROM="JAC App <noreply@...>"
#
# Generar secretos seguros (ejecutar en terminal):
#   openssl rand -base64 64    ← para JWT_SECRET y JWT_REFRESH_SECRET
#   openssl rand -hex 32       ← para ENCRYPTION_MASTER_KEY
#   openssl rand -base64 32    ← para BOOTSTRAP_TOKEN
# ══════════════════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────────────────
# docker-compose construye DATABASE_URL automáticamente con estas variables.
DB_NAME=jac_db
DB_USER=jac_user
DB_PASSWORD="<CAMBIAR: contraseña segura, ej. openssl rand -base64 24>"

# connection_limit=5 → máximo de conexiones Prisma en este proceso.
# En un VPS 2GB no quieres más de 10–15 conexiones totales a Postgres.
# pool_timeout=10 → si no hay conexión libre en 10s, lanza error en vez de colgar.
# docker-compose.yml sobreescribe DATABASE_URL con host=postgres (contenedor).
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public&connection_limit=5&pool_timeout=10

# ── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Dominio de producción.
# ⚠ El DNS (registro A) debe apuntar a la IP del servidor ANTES de levantar Caddy.
# Caddy obtiene el certificado SSL automáticamente de Let's Encrypt.
# Ejemplos: mi-jac.com  |  app.asojac.org  |  juntas.mi-dominio.co
DOMAIN=<CAMBIAR: tu-dominio.com>

# ── Subdominios de monitoreo (monitor.*, grafana.*) ─────────────────────────
# Basicauth para Caddy (protege monitor y grafana). Usuario: admin
# Generar hash: docker run --rm caddy:2.9-alpine caddy hash-password --plaintext 'tu_password'
# IMPORTANTE: Duplicar cada $ del hash (ej: $2a$14$xxx → $$2a$$14$$xxx)
MONITOR_BASICAUTH_HASH="<PEGAR_HASH_AQUI>"

# Grafana (cambiar en primer login)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CAMBIAR: contraseña segura>

# URL pública del backend (sin /api al final).
# Con Caddy en el mismo dominio: https://${DOMAIN}
API_PUBLIC_URL=<CAMBIAR: https://tu-dominio.com>

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=<CAMBIAR: https://tu-dominio.com>

# ── JWT ───────────────────────────────────────────────────────────────────
# ⚠️  GENERAR CLAVES NUEVAS — NO reutilizar las de desarrollo
# Comando: openssl rand -base64 64
JWT_SECRET=<GENERAR: openssl rand -base64 64>
JWT_REFRESH_SECRET=<GENERAR: openssl rand -base64 64>

# ── Encriptación de credenciales Wompi (por junta) ───────────────────────
# ⚠️  GENERAR CLAVE NUEVA para producción (diferente a la de dev).
#    Si ya tienes datos en producción encriptados, NO cambiar esta clave.
# Comando: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=<GENERAR: openssl rand -hex 32>

# ── Bootstrap (primera inicialización) ───────────────────────────────────
# Comando: openssl rand -base64 32
# Después del primer uso puedes dejarla vacía o eliminarla del archivo.
BOOTSTRAP_TOKEN=<GENERAR: openssl rand -base64 32>

# ── Wompi – Facturación plataforma ────────────────────────────────────────
# ⚠️  Las claves de SANDBOX del .env de dev NO sirven en producción.
#    Obtener claves PRODUCCIÓN desde: https://dashboard.wompi.co → Desarrolladores
#
# Dev (sandbox, SOLO referencia):
#   WOMPI_PRIVATE_KEY=prv_test_w30wZM64WmIGc3Xojjy9eLirRkEeXDt5
#   WOMPI_PUBLIC_KEY=pub_test_xYFlwzWb1A6NIwLpU7pGv78OoU6avhXh
#   WOMPI_INTEGRITY_SECRET=test_integrity_hC2gYVZo8LTOszEO25kcHNYbc0fxc1AW
#   WOMPI_EVENTS_SECRET=test_events_woe8eO51BUvt186LlKQdXZaSkqV2tEl1

WOMPI_ENVIRONMENT=production
WOMPI_PRIVATE_KEY=<CAMBIAR: prv_prod_...>
WOMPI_PUBLIC_KEY=<CAMBIAR: pub_prod_...>
WOMPI_INTEGRITY_SECRET=<CAMBIAR: prod_integrity_...>
WOMPI_EVENTS_SECRET=<CAMBIAR: prod_events_...>

# URLs de retorno Wompi (deben coincidir con tu dominio de producción)
# Tras la landing, las rutas están bajo /app.
WOMPI_REDIRECT_URL=<CAMBIAR: https://tu-dominio.com>/app/pagos/retorno
WOMPI_REDIRECT_URL_FACTURAS=<CAMBIAR: https://tu-dominio.com>/app/facturas-plataforma/retorno

# ── AWS S3 + CloudFront ───────────────────────────────────────────────────
# Mismas credenciales IAM que dev, pero se recomienda un bucket separado para prod.
# Bucket dev: asojac-bucket-dev
# Crear bucket prod: asojac-bucket-prod  (o el nombre que prefieras)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CAMBIAR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CAMBIAR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET_NAME=<CAMBIAR: asojac-bucket-prod>
# CloudFront: si usas la misma distribución para prod, poner el mismo dominio.
# Si creas una nueva distribución para el bucket de prod, actualizar este valor.
AWS_CLOUDFRONT_DOMAIN=<CAMBIAR: xxxxxxxxxx.cloudfront.net>
AWS_ALGORITHM=HS512

# ── Backups ───────────────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/jac
RETENTION_DAYS=30
# Zona horaria para el nombre del archivo (America/Bogota = Colombia)
BACKUP_TIMEZONE=America/Bogota

# Bucket S3 exclusivo para backups de BD (distinto al de documentos de usuarios).
# Recomendado: crear un bucket separado, ej. "asojac-backups-prod"
# Razón: permite configurar lifecycle rules distintas (Glacier, retención, etc.)
# sin afectar los documentos de usuarios.
#
# Crear bucket en AWS Console → S3 → Create bucket
# Asegurarse de que el IAM user (AWS_ACCESS_KEY_ID) tenga permisos:
#   s3:PutObject, s3:GetObject, s3:ListBucket, s3:DeleteObject
#   sobre arn:aws:s3:::asojac-backups-prod/*
#
# Si prefieres usar el mismo bucket de documentos, usa:
#   AWS_BACKUP_BUCKET=${AWS_S3_BUCKET_NAME}
AWS_BACKUP_BUCKET=<CAMBIAR: asojac-backups-prod>

# Prefijo (carpeta) dentro del bucket donde se guardan los backups.
# Permite compartir bucket con otros usos si fuera necesario.
AWS_BACKUP_PREFIX=db-backups

# ── Email (AWS SES) ───────────────────────────────────────────────────────
# Ver docs/EMAIL_SES_SETUP.md para crear credenciales SMTP en SES.
EMAIL_TRANSPORT=ses
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=<CAMBIAR: credencial SMTP de SES>
SMTP_PASS=<CAMBIAR: credencial SMTP de SES>
# Valores con espacios OBLIGATORIAMENTE entre comillas (evita "key cannot contain a space")
EMAIL_FROM="JAC App <noreply@jacapp.online>"
APP_PUBLIC_URL=<CAMBIAR: https://jacapp.online>

# ── pgAdmin (opcional — solo para docker-compose.monitoring.yml --profile pgadmin) ──
PGADMIN_EMAIL=<CAMBIAR: admin@tu-jac.com>
PGADMIN_PASSWORD=<CAMBIAR>
