{
  "name": "jac-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "db:migrate": "npm run prisma:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:studio": "npm run prisma:studio -w backend",
    "db:reset": "npm run prisma:reset -w backend"
  },
  "dependencies": {
    "@nestjs/platform-express": "^11.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
