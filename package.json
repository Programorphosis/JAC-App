{
  "name": "jac-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "db:migrate": "npm run prisma:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:studio": "npm run prisma:studio -w backend",
    "db:reset": "npm run prisma:reset -w backend",
    "docker:dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env.local up -d --build",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:prod:up": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production down",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/platform-express": "^11.0.1"
  },
  "devDependencies": {
    "@angular/service-worker": "^19.2.19",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2"
  },
  "lint-staged": {
    "apps/backend/src/**/*.ts": [
      "npm run lint --workspace=backend -- --fix"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
