# ──────────────────────────────────────────────────────────────────────────
# Caddyfile — Reverse proxy con HTTPS automático (Let's Encrypt)
#
# INSTRUCCIONES:
#   1. En .env.production, asegúrate de tener:
#         DOMAIN=tu-dominio.com
#   2. El dominio debe apuntar (DNS A/AAAA) a la IP del servidor ANTES de
#      levantar Caddy por primera vez. Let's Encrypt valida el dominio.
#   3. Los certificados se renuevan automáticamente.
#
# Subdominios de monitoreo (monitor.{DOMAIN}, grafana.{DOMAIN}):
#   - Requieren DNS A para monitor.* y grafana.* apuntando a esta IP
#   - MONITOR_BASICAUTH en .env.production: "admin <hash>"
#   - Generar hash: docker run --rm caddy:2.9-alpine caddy hash-password --plaintext 'tu_password'
#   - Por defecto usa un hash inseguro; cambiar en producción
#
# Puertos requeridos abiertos en firewall:
#   80  → HTTP (Caddy redirige automáticamente a HTTPS)
#   443 → HTTPS
# ──────────────────────────────────────────────────────────────────────────

{$DOMAIN} {
    # Todo el tráfico web va al contenedor frontend (Angular + nginx interno)
    reverse_proxy frontend:80

    # Logs de acceso en formato JSON (compatible con agregadores de logs)
    log {
        output stdout
        format json
    }

    # Headers de seguridad adicionales
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    # Compresión (complementa la de nginx)
    encode zstd gzip
}

# ── Uptime Kuma (monitor.{DOMAIN}) ────────────────────────────────────────
monitor.{$DOMAIN} {
    basicauth /* {
        {$MONITOR_BASICAUTH}
    }
    reverse_proxy uptime-kuma:3001
    log { output stdout format json }
    header -Server
}

# ── Grafana (grafana.{DOMAIN}) ─────────────────────────────────────────────
grafana.{$DOMAIN} {
    basicauth /* {
        {$MONITOR_BASICAUTH}
    }
    reverse_proxy grafana:3000
    log { output stdout format json }
    header -Server
}
