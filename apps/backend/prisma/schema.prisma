// SCHEMA BASE v1 - Sistema JAC
// Referencia: docs/SCHEMA BASE v1.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum RolNombre {
  PLATFORM_ADMIN
  ADMIN
  SECRETARIA
  TESORERA
  FISCAL
  RECEPTOR_AGUA
  AFILIADO
}

enum EstadoLaboralTipo {
  TRABAJANDO
  NO_TRABAJANDO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  ONLINE
}

enum TipoPago {
  JUNTA
  CARTA
}

enum TipoIntencionPago {
  JUNTA
  CARTA
}

enum EstadoRequisitoTipo {
  AL_DIA
  MORA
}

enum EstadoCartaTipo {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoCambioRequisito {
  ESTADO
  OBLIGACION
}

enum EstadoSuscripcion {
  ACTIVA
  SUSPENDIDA
  CANCELADA
  PRUEBA
  VENCIDA
}

enum EstadoFactura {
  PENDIENTE
  PAGADA
  PARCIAL
  VENCIDA
  CANCELADA
}

enum AlcanceAviso {
  PLATAFORMA
  TODAS_JUNTAS
  JUNTA_ESPECIFICA
}

enum TipoFactura {
  MENSUAL
  MANUAL
  AJUSTE
  SUSCRIPCION
  RENOVACION
  OVERRIDE
  UPGRADE
}

enum MetodoPagoFactura {
  EFECTIVO
  TRANSFERENCIA
  ONLINE
  CHEQUE
  OTRO
}

//////////////////////////////////////////////////////
// PLANES Y SUSCRIPCIONES (PA-4)
//////////////////////////////////////////////////////

model Plan {
  id                String   @id @default(uuid())
  nombre            String   @unique
  descripcion       String?
  precioMensual     Int      // COP
  precioAnual       Int      // COP
  limiteUsuarios    Int?     // null + permiteUsuariosIlimitados = ilimitado
  limiteStorageMb   Int?     // null + permiteStorageIlimitado = ilimitado
  limiteCartasMes   Int?     // null + permiteCartasIlimitadas = ilimitado
  permiteUsuariosIlimitados  Boolean @default(false)
  permiteStorageIlimitado    Boolean @default(false)
  permiteCartasIlimitadas    Boolean @default(false)
  esPersonalizable  Boolean  @default(false)
  diasPrueba        Int      @default(0)
  activo            Boolean  @default(true)
  fechaCreacion     DateTime @default(now())
  // Precios por demanda (solo si esPersonalizable). COP por unidad adicional.
  precioPorUsuarioAdicional  Int?
  precioPorMbAdicional       Int?
  precioPorCartaAdicional    Int?

  suscripciones       Suscripcion[]
  suscripcionesPendientes Suscripcion[] @relation("PlanPendiente")
}

model Suscripcion {
  id                String            @id @default(uuid())
  juntaId           String            @unique
  junta             Junta             @relation(fields: [juntaId], references: [id], onDelete: Cascade)
  planId            String
  plan              Plan              @relation(fields: [planId], references: [id])
  fechaInicio       DateTime         @default(now())
  fechaVencimiento  DateTime
  periodo           String?           // 'mensual' | 'anual' – para facturación renovación
  estado            EstadoSuscripcion @default(PRUEBA)
  overrideLimiteUsuarios    Int?
  overrideLimiteStorageMb   Int?
  overrideLimiteCartasMes   Int?
  esPlanPersonalizado       Boolean   @default(false)
  precioPersonalizado       Decimal?  @db.Decimal(12, 2)
  motivoPersonalizacion    String?
  fechaCreacion             DateTime  @default(now())
  // Downgrade programado: efectivo al fin del ciclo (cuando fechaVencimiento < hoy)
  planIdPendiente   String?
  planPendiente     Plan?             @relation("PlanPendiente", fields: [planIdPendiente], references: [id])
  periodoPendiente  String?           // 'mensual' | 'anual' para cuando se aplique el downgrade
  // Cancelación al final del período: la suscripción sigue ACTIVA hasta fechaVencimiento
  // El cron de renovación omite suscripciones con cancelacionSolicitada=true
  cancelacionSolicitada Boolean @default(false)
  fechaCancelacionSolicitada DateTime?

  facturas          Factura[]

  @@index([juntaId])
  @@index([planId])
}

//////////////////////////////////////////////////////
// FACTURACIÓN PLATAFORMA (PA-6)
//////////////////////////////////////////////////////

model Factura {
  id                String         @id @default(uuid())
  juntaId           String
  junta             Junta         @relation(fields: [juntaId], references: [id], onDelete: Cascade)
  suscripcionId     String?
  suscripcion       Suscripcion?   @relation(fields: [suscripcionId], references: [id], onDelete: SetNull)
  monto             Int            // COP
  fechaEmision      DateTime      @default(now())
  fechaVencimiento  DateTime
  estado            EstadoFactura @default(PENDIENTE)
  tipo              TipoFactura   @default(MENSUAL)
  referenciaExterna String?
  metadata          Json?
  creadoPorId       String?
  creadoPor         Usuario?      @relation("FacturaCreadaPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  fechaCreacion     DateTime      @default(now())

  pagos             PagoFactura[]
  intencionesPago   IntencionPagoFactura[]

  @@index([juntaId])
  @@index([suscripcionId])
  @@index([estado])
  @@index([fechaEmision])
}

/// Intención de pago online de factura plataforma (junta → plataforma).
/// FACTURACION_PLATAFORMA_PAGO_ONLINE_ANALISIS.md
model IntencionPagoFactura {
  id             String   @id @default(uuid())
  facturaId      String
  factura        Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  juntaId        String
  junta          Junta    @relation(fields: [juntaId], references: [id], onDelete: Cascade)
  montoCents     Int
  wompiLinkId    String   @unique
  iniciadoPorId  String
  iniciadoPor    Usuario  @relation("IntencionPagoFacturaIniciadaPor", fields: [iniciadoPorId], references: [id], onDelete: Cascade)
  fechaCreacion  DateTime @default(now())

  @@index([juntaId])
  @@index([facturaId])
}

model PagoFactura {
  id                String            @id @default(uuid())
  facturaId         String
  factura           Factura           @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  monto             Int               // COP
  fecha             DateTime         @default(now())
  metodo            MetodoPagoFactura
  referencia        String?
  referenciaExterna String?
  fechaCreacion     DateTime         @default(now())

  @@index([facturaId])
}

//////////////////////////////////////////////////////
// JUNTA (multi-tenant base)
//////////////////////////////////////////////////////

model Junta {
  id                  String    @id @default(uuid())
  nombre              String
  nit                 String?   @unique
  fechaCreacion       DateTime  @default(now())
  montoCarta          Int?
  vigenciaCartaMeses  Int?      @default(3)  // meses de validez de la carta; null = 3 por defecto
  activo              Boolean   @default(true)
  fechaBaja           DateTime?

  // PA-2: datos de contacto y región
  telefono            String?
  email               String?
  direccion           String?
  ciudad              String?
  departamento        String?
  personeriaJuridica  String?   // ej. "385 de 2004-12-14" – para cartas
  membreteUrl         String?   // URL de imagen de membrete escaneado (versión premium)
  escudoS3Key         String?   // S3 key: juntas/{juntaId}/escudo.png – obligatorio para expedir cartas
  enMantenimiento     Boolean   @default(false)

  // Wompi por junta – credenciales encriptadas (WOMPI_POR_JUNTA_DOC)
  wompiPrivateKey      String?   // prv_test_... o prv_prod_...
  wompiPublicKey       String?   // pub_test_... o pub_prod_...
  wompiIntegritySecret String?   // test_integrity_... o prod_integrity_...
  wompiEventsSecret    String?   // test_events_... o prod_events_...
  wompiEnvironment     String?   // "sandbox" | "production"

  // Aceptación términos de servicio (Ley 527, documentación legal)
  terminosAceptadosEn   DateTime? // fecha de aceptación
  terminosVersion       String?   // versión aceptada (ej. "2026-02-25")

  usuarios         Usuario[]
  tarifas          Tarifa[]
  consecutivos     Consecutivo[]
  pagos            Pago[]
  intencionesPago  IntencionPago[]
  requisitos       RequisitoTipo[]
  cartas           Carta[]
  auditorias       Auditoria[]
  suscripcion     Suscripcion?
  facturas        Factura[]
  intencionesPagoFactura IntencionPagoFactura[]
  notas           NotaJunta[]
  avisos          AvisoPlataforma[]
}

//////////////////////////////////////////////////////
// NOTAS JUNTA (PA-7 – Operaciones y soporte)
//////////////////////////////////////////////////////

model NotaJunta {
  id           String   @id @default(uuid())
  juntaId      String
  junta        Junta    @relation(fields: [juntaId], references: [id], onDelete: Cascade)
  contenido    String
  creadoPorId  String
  creadoPor    Usuario  @relation(fields: [creadoPorId], references: [id], onDelete: Cascade)
  fechaCreacion DateTime @default(now())

  @@index([juntaId])
}


//////////////////////////////////////////////////////
// USUARIOS
//////////////////////////////////////////////////////

model Usuario {
  id                String   @id @default(uuid())
  juntaId           String?
  junta             Junta?   @relation(fields: [juntaId], references: [id])

  tipoDocumento     String
  numeroDocumento   String
  nombres           String
  apellidos         String
  telefono          String?
  direccion         String?
  email             String?  // para recuperación de contraseña; se pide al cambiar por primera vez
  lugarExpedicion   String?  // lugar de expedición del documento (ej. Bogotá, Villavicencio)
  activo            Boolean  @default(true)
  fechaCreacion     DateTime @default(now())
  passwordHash      String   // bcrypt hash; requerido para login
  requiereCambioPassword Boolean @default(true) // true = debe cambiar en primer login

  // Libro de afiliados (físico) – usados en cartas
  fechaAfiliacion   DateTime?  // fecha en que se afilió a la junta
  folio             Int?      // número de folio del libro donde está registrado
  numeral           Int?      // consecutivo del libro

  roles             UsuarioRol[]
  historialLaboral   HistorialLaboral[]
  historialCreadoPor HistorialLaboral[] @relation("HistorialCreadoPor")
  pagos             Pago[]
  pagosRegistrados  Pago[]             @relation("PagoRegistradoPor")
  cartas            Carta[]
  cartasEmitidas    Carta[]            @relation("CartaEmitidaPor")
  estadosRequisito   EstadoRequisito[]
  historialRequisito HistorialRequisito[]
  requisitosModificadosPor HistorialRequisito[] @relation("RequisitoCambiadoPor")
  requisitosComoModificador RequisitoTipo[]     @relation("RequisitoModificador")
  documentos        Documento[]
  documentosSubidos Documento[]       @relation("DocumentoSubidoPor")
  auditorias        Auditoria[]
  intencionesPago   IntencionPago[]
  intencionesIniciadas IntencionPago[] @relation("IntencionIniciadaPor")
  intencionesPagoFactura IntencionPagoFactura[] @relation("IntencionPagoFacturaIniciadaPor")
  facturasCreadas  Factura[]         @relation("FacturaCreadaPor")
  notasJunta       NotaJunta[]
  codigosRecuperacion CodigoRecuperacion[]

  @@unique([juntaId, numeroDocumento])
  @@index([email])
  @@index([juntaId])
}

//////////////////////////////////////////////////////
// ROLES
//////////////////////////////////////////////////////

model Rol {
  id        String     @id @default(uuid())
  nombre    RolNombre  @unique
  usuarios  UsuarioRol[]
}

model UsuarioRol {
  usuarioId String
  rolId     String

  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  rol       Rol     @relation(fields: [rolId], references: [id])

  @@id([usuarioId, rolId])
}

//////////////////////////////////////////////////////
// CÓDIGO RECUPERACIÓN CONTRASEÑA
//////////////////////////////////////////////////////

model CodigoRecuperacion {
  id        String   @id @default(uuid())
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  codigo    String   // 6 dígitos
  expiraEn  DateTime
  usado    Boolean  @default(false)
  fechaCreacion DateTime @default(now())

  @@index([usuarioId])
  @@index([codigo, expiraEn])
}

//////////////////////////////////////////////////////
// HISTORIAL LABORAL
//////////////////////////////////////////////////////

model HistorialLaboral {
  id            String             @id @default(uuid())
  usuarioId     String
  usuario       Usuario            @relation(fields: [usuarioId], references: [id])

  estado        EstadoLaboralTipo
  fechaInicio   DateTime
  fechaFin      DateTime?

  creadoPorId   String
  creadoPor     Usuario            @relation("HistorialCreadoPor", fields: [creadoPorId], references: [id])

  fechaCreacion DateTime           @default(now())

  @@index([usuarioId])
}

//////////////////////////////////////////////////////
// TARIFAS
//////////////////////////////////////////////////////

model Tarifa {
  id             String   @id @default(uuid())
  juntaId        String
  junta          Junta    @relation(fields: [juntaId], references: [id])

  estadoLaboral  EstadoLaboralTipo
  valorMensual   Int
  fechaVigencia  DateTime

  fechaCreacion  DateTime @default(now())

  @@unique([juntaId, estadoLaboral, fechaVigencia])
}

//////////////////////////////////////////////////////
// PAGOS
//////////////////////////////////////////////////////

model Pago {
  id                String     @id @default(uuid())

  juntaId           String
  junta             Junta      @relation(fields: [juntaId], references: [id])

  usuarioId         String
  usuario           Usuario    @relation(fields: [usuarioId], references: [id])

  tipo              TipoPago
  metodo            MetodoPago
  monto             Int

  consecutivo       Int
  referenciaExterna String?    @unique

  registradoPorId   String
  registradoPor     Usuario    @relation("PagoRegistradoPor", fields: [registradoPorId], references: [id])

  fechaPago         DateTime   @default(now())

  /// Solo para tipo CARTA: true = vigente (puede solicitar carta); false = consumido (carta ya emitida).
  /// null = otros tipos de pago o datos legacy.
  vigencia          Boolean?

  @@unique([juntaId, tipo, consecutivo])
  @@index([juntaId])
  @@index([usuarioId])
  @@index([juntaId, fechaPago])   // listados por junta filtrados por rango de fechas
}

model IntencionPago {
  id             String           @id @default(uuid())

  usuarioId      String
  usuario        Usuario          @relation(fields: [usuarioId], references: [id])

  juntaId        String
  junta          Junta            @relation(fields: [juntaId], references: [id])

  tipoPago       TipoIntencionPago @default(JUNTA)
  montoCents     Int
  wompiLinkId    String           @unique
  referencia     String

  iniciadoPorId  String
  iniciadoPor    Usuario          @relation("IntencionIniciadaPor", fields: [iniciadoPorId], references: [id])

  fechaCreacion  DateTime         @default(now())

  @@index([juntaId])
  @@index([usuarioId])
}

//////////////////////////////////////////////////////
// REQUISITOS ADICIONALES (agua, basura, etc.)
//////////////////////////////////////////////////////

model RequisitoTipo {
  id                   String   @id @default(uuid())
  juntaId              String
  junta                Junta    @relation(fields: [juntaId], references: [id])

  nombre               String
  modificadorId        String?
  modificador          Usuario? @relation("RequisitoModificador", fields: [modificadorId], references: [id])
  tieneCorteAutomatico Boolean @default(true)
  activo               Boolean  @default(true)
  fechaCreacion        DateTime @default(now())

  estados              EstadoRequisito[]
  historial            HistorialRequisito[]

  @@index([juntaId])
}

model EstadoRequisito {
  usuarioId           String
  usuario             Usuario  @relation(fields: [usuarioId], references: [id])
  requisitoTipoId     String
  requisitoTipo       RequisitoTipo @relation(fields: [requisitoTipoId], references: [id], onDelete: Cascade)

  estado              EstadoRequisitoTipo
  obligacionActiva    Boolean  @default(true)
  fechaUltimoCambio   DateTime @default(now())

  @@id([usuarioId, requisitoTipoId])
  @@index([requisitoTipoId])
}

model HistorialRequisito {
  id                 String           @id @default(uuid())

  usuarioId          String
  usuario            Usuario          @relation(fields: [usuarioId], references: [id])
  requisitoTipoId     String
  requisitoTipo       RequisitoTipo    @relation(fields: [requisitoTipoId], references: [id], onDelete: Cascade)

  tipoCambio         TipoCambioRequisito

  estadoAnterior     EstadoRequisitoTipo?
  estadoNuevo        EstadoRequisitoTipo?

  obligacionAnterior Boolean?
  obligacionNueva    Boolean?

  cambiadoPorId      String?
  cambiadoPor        Usuario?         @relation("RequisitoCambiadoPor", fields: [cambiadoPorId], references: [id])

  cambioAutomatico   Boolean  @default(false)
  fechaCambio        DateTime @default(now())

  @@index([usuarioId])
  @@index([requisitoTipoId])
}

//////////////////////////////////////////////////////
// CARTAS
//////////////////////////////////////////////////////

model Carta {
  id              String            @id @default(uuid())

  juntaId         String
  junta           Junta             @relation(fields: [juntaId], references: [id])

  usuarioId       String
  usuario         Usuario           @relation(fields: [usuarioId], references: [id])

  consecutivo     Int?              // null = PENDIENTE; asignado al aprobar
  anio            Int               // año de emisión; al solicitar = año actual

  estado          EstadoCartaTipo
  qrToken         String            @unique  // UUID; generado al solicitar, usado en QR al aprobar

  fechaSolicitud  DateTime          @default(now())
  fechaEmision    DateTime?
  vigenciaHasta   DateTime?         // fecha límite de validez; null = legacy o sin config

  emitidaPorId    String?
  emitidaPor      Usuario?          @relation("CartaEmitidaPor", fields: [emitidaPorId], references: [id])

  rutaPdf         String?
  hashDocumento   String?
  motivoRechazo   String?

  @@unique([juntaId, anio, consecutivo])
  @@index([juntaId])
  @@index([usuarioId])
  @@index([juntaId, estado])         // filtros por estado dentro de una junta
  @@index([juntaId, fechaSolicitud]) // listados paginados ordenados por fecha
}

//////////////////////////////////////////////////////
// DOCUMENTOS
//////////////////////////////////////////////////////

model Documento {
  id           String   @id @default(uuid())

  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])

  tipo         String
  rutaS3       String
  sizeBytes    BigInt?  // PA5-1: tamaño real en bytes para cálculo de storage

  subidoPorId  String
  subidoPor    Usuario  @relation("DocumentoSubidoPor", fields: [subidoPorId], references: [id])

  fechaSubida  DateTime @default(now())

  @@index([usuarioId])
}

//////////////////////////////////////////////////////
// CONSECUTIVOS
//////////////////////////////////////////////////////

model Consecutivo {
  id          String   @id @default(uuid())

  juntaId     String
  junta       Junta    @relation(fields: [juntaId], references: [id])

  tipo        String
  anio        Int
  valorActual Int

  @@unique([juntaId, tipo, anio])
}

//////////////////////////////////////////////////////
// AVISOS PLATAFORMA (PA-9)
//////////////////////////////////////////////////////

model AvisoPlataforma {
  id                String        @id @default(uuid())
  titulo            String
  contenido         String        @db.Text
  fechaPublicacion  DateTime      @default(now())
  activo            Boolean       @default(true)
  alcance           AlcanceAviso  @default(TODAS_JUNTAS)
  juntaId           String?
  junta             Junta?        @relation(fields: [juntaId], references: [id], onDelete: SetNull)
  fechaCreacion     DateTime      @default(now())

  @@index([activo])
  @@index([alcance])
  @@index([juntaId])
}

//////////////////////////////////////////////////////
// AUDITORIA CENTRAL
//////////////////////////////////////////////////////

model Auditoria {
  id             String   @id @default(uuid())

  juntaId        String
  junta          Junta    @relation(fields: [juntaId], references: [id])

  entidad        String
  entidadId      String
  accion         String
  metadata       Json

  ejecutadoPorId String
  ejecutadoPor   Usuario  @relation(fields: [ejecutadoPorId], references: [id])

  fecha          DateTime @default(now())

  @@index([juntaId])
  @@index([entidad])
  @@index([juntaId, fecha])  // listados de auditoría paginados por fecha
}
