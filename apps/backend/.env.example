# Base de datos
DATABASE_URL="postgresql://postgres:password@localhost:5432/jac_db_dev?schema=public"

# JWT
JWT_SECRET=change-in-production
JWT_REFRESH_SECRET=change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:4200

# Logs
LOG_LEVEL=debug

# Bootstrap (solo para primera inicialización)
BOOTSTRAP_TOKEN=change-in-production

# ========== Encriptación (WOMPI por junta) ==========
# Clave maestra para encriptar credenciales Wompi en BD. 32 bytes hex.
# Generar: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=

# ========== WOMPI (Facturación plataforma – reservado) ==========
# Los pagos de afiliados a juntas usan credenciales por junta (Junta.wompi*).
# Estas variables son para facturación de suscripciones.
WOMPI_ENVIRONMENT=sandbox
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# URL donde Wompi redirige tras el pago. Debe coincidir con el puerto de tu frontend.
# Angular por defecto: 4200. Si usas otro (ej. 5173), ajusta aquí.
WOMPI_REDIRECT_URL=http://localhost:4200/pagos/retorno

# URL de retorno para pago de facturas (junta → plataforma). Si no se define, se deriva de WOMPI_REDIRECT_URL.
WOMPI_REDIRECT_URL_FACTURAS=http://localhost:4200/facturas-plataforma/retorno

# URL pública del backend (para mostrar webhook a las juntas). Producción: https://api.tudominio.com
# Local con ngrok: https://xxx.ngrok-free.app
API_PUBLIC_URL=

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_CLOUDFRONT_DOMAIN=
AWS_ALGORITHM=HS512
