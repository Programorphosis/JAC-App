# App
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database (desarrollo local con Docker)
DATABASE_URL=postgresql://jac_user:jac_password_dev@postgres:5432/jac_db_dev?schema=public

# JWT (valores de desarrollo - cambiar en producción)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (configurar cuando se necesite)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Wompi - Pagos online (Fase 5). Ver docs/WOMPI_VARIABLES_ENTORNO.md
WOMPI_ENVIRONMENT=sandbox
WOMPI_PRIVATE_KEY=
WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_REDIRECT_URL=http://localhost:5173/pagos/retorno

# CORS
CORS_ORIGIN=http://localhost:5173

# Logs
LOG_LEVEL=debug

# Bootstrap (solo para primera inicialización; proteger en producción)
BOOTSTRAP_TOKEN=your-bootstrap-token-here
