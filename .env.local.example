# ══════════════════════════════════════════════════════════════════════════
# .env.local — JAC App (Docker local)
# Copiar a .env.local y ajustar si es necesario.
#   cp .env.local.example .env.local
# ══════════════════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────────────────
# Valores con espacios deben ir entre comillas para evitar "key cannot contain a space"
DB_NAME=jac_db
DB_USER=jac_user
DB_PASSWORD="local_dev_password_change_me"

# ── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Dominio local (Caddy sirve HTTP sin SSL)
DOMAIN=localhost
API_PUBLIC_URL=http://localhost
CORS_ORIGIN=http://localhost

# ── JWT ───────────────────────────────────────────────────────────────────
# Generar: openssl rand -base64 64
JWT_SECRET="change-in-local-dev"
JWT_REFRESH_SECRET="change-in-local-dev-refresh"

# ── Encriptación (credenciales Wompi por junta) ───────────────────────────
# Generar: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=CAMBIAR_ENCRYPTION_MASTER_KEY

# ── Bootstrap (primera inicialización) ─────────────────────────────────────
# Generar: openssl rand -base64 32
BOOTSTRAP_TOKEN="change-in-local-dev"

# ── Wompi (sandbox para pruebas) ──────────────────────────────────────────
WOMPI_ENVIRONMENT=sandbox
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_REDIRECT_URL=http://localhost/app/pagos/retorno
WOMPI_REDIRECT_URL_FACTURAS=http://localhost/app/facturas-plataforma/retorno

# ── Email (MailHog en Docker) ─────────────────────────────────────────────
# SMTP_HOST=mailhog (nombre del servicio en la red interna Docker)
EMAIL_TRANSPORT=mailhog
SMTP_HOST=mailhog
SMTP_PORT=1025
EMAIL_FROM="JAC App <noreply@localhost>"
APP_PUBLIC_URL=http://localhost

# ── AWS (opcional en local; dejar vacío si no usas S3) ─────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CAMBIAR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CAMBIAR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET_NAME=CAMBIAR_AWS_S3_BUCKET_NAME   
AWS_CLOUDFRONT_DOMAIN=CAMBIAR_AWS_CLOUDFRONT_DOMAIN
AWS_ALGORITHM=HS512
